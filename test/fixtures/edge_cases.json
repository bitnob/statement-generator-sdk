{
  "edge_cases": [
    {
      "description": "Empty transaction list",
      "input": {
        "account": {
          "number": "****5678",
          "holder_name": "Jane Smith",
          "currency": "USD"
        },
        "period_start": "2024-01-01T00:00:00Z",
        "period_end": "2024-01-31T23:59:59Z",
        "opening_balance": 1500.00,
        "transactions": []
      },
      "expected": {
        "closing_balance": 1500.00,
        "total_credits": 0,
        "total_debits": 0,
        "transaction_count": 0
      }
    },
    {
      "description": "Single transaction",
      "input": {
        "account": {
          "number": "****9999",
          "holder_name": "Bob Wilson",
          "currency": "USD"
        },
        "period_start": "2024-01-01T00:00:00Z",
        "period_end": "2024-01-31T23:59:59Z",
        "opening_balance": 500.00,
        "transactions": [
          {
            "id": "TXN001",
            "date": "2024-01-15T10:00:00Z",
            "description": "Payment Received",
            "amount": 250.00,
            "type": "credit"
          }
        ]
      },
      "expected": {
        "closing_balance": 750.00,
        "total_credits": 250.00,
        "total_debits": 0,
        "transaction_count": 1
      }
    },
